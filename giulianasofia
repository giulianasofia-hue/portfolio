02Fa><\u002Fdiv><\u002Fdiv>\n      <div><div style=\"font-family:'Bebas Neue',sans-serif;font-size:.82rem;letter-spacing:.14em;color:var(--terra);margin-bottom:5px;\">Ubicación<\u002Fdiv><div style=\"font-size:.88rem;color:var(--choc);\">Buenos Aires, Argentina<\u002Fdiv><\u002Fdiv>\n      <div><div style=\"font-family:'Bebas Neue',sans-serif;font-size:.82rem;letter-spacing:.14em;color:var(--terra);margin-bottom:5px;\">Idiomas<\u002Fdiv><div style=\"font-size:.88rem;color:var(--choc);\">🇦🇷 Español · 🇺🇸 Inglés<\u002Fdiv><\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <footer style=\"background:var(--choc-deep);padding:26px 56px;display:flex;justify-content:space-between;align-items:center;font-size:.74rem;color:rgba(244,235,221,.4);letter-spacing:.04em;\">\n    <span>© 2026 <span style=\"color:var(--terra-light);\">Giuliana Sofia<\u002Fspan> Bastianelli Molina<\u002Fspan>\n    <span>Hecho con ✦ en Buenos Aires<\u002Fspan>\n  <\u002Ffooter>\n\n<\u002Fdiv>\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\">\nclass Component extends DCLogic {\n  componentDidMount() {\n    const cursor = document.getElementById('gsb-cursor');\n    const bar = document.getElementById('gsb-progress');\n    const deco = document.getElementById('gsb-hero-deco');\n    const isFine = window.matchMedia('(pointer:fine)').matches;\n\n    if (cursor && isFine) {\n      this.onMove = (e) => { cursor.style.left = e.clientX + 'px'; cursor.style.top = e.clientY + 'px'; };\n      document.addEventListener('mousemove', this.onMove, { passive: true });\n      const grow = () => { cursor.style.width = '44px'; cursor.style.height = '44px'; cursor.style.opacity = '0.5'; cursor.style.background = 'var(--camel)'; };\n      const shrink = () => { cursor.style.width = '11px'; cursor.style.height = '11px'; cursor.style.opacity = '1'; cursor.style.background = 'var(--terra)'; };\n      this.hoverEls = Array.from(document.querySelectorAll('a, [data-cursor], image-slot'));\n      this.hoverEls.forEach(el => { el.addEventListener('mouseenter', grow); el.addEventListener('mouseleave', shrink); });\n    } else if (cursor) {\n      cursor.style.display = 'none';\n    }\n\n    this.onScroll = () => {\n      const st = window.scrollY || document.documentElement.scrollTop;\n      const h = document.documentElement.scrollHeight - window.innerHeight;\n      if (bar) bar.style.width = (h > 0 ? (st / h * 100) : 0) + '%';\n      if (deco) deco.style.transform = 'translateY(' + (st * 0.18) + 'px)';\n    };\n    window.addEventListener('scroll', this.onScroll, { passive: true });\n    this.onScroll();\n\n    this.io = new IntersectionObserver((entries) => {\n      entries.forEach(en => {\n        if (en.isIntersecting) {\n          en.target.style.opacity = '1';\n          en.target.style.transform = 'none';\n          this.io.unobserve(en.target);\n        }\n      });\n    }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });\n    document.querySelectorAll('[data-reveal]').forEach(el => this.io.observe(el));\n  }\n\n  componentWillUnmount() {\n    if (this.onMove) document.removeEventListener('mousemove', this.onMove);\n    if (this.onScroll) window.removeEventListener('scroll', this.onScroll);\n    if (this.io) this.io.disconnect();\n  }\n\n  renderVals() {\n    const scroll = (dir) => {\n      const c = document.getElementById('ace-carousel');\n      if (c) c.scrollBy({ left: dir * 358, behavior: 'smooth' });\n    };\n    return {\n      aceLeft: () => scroll(-1),\n      aceRight: () => scroll(1),\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
